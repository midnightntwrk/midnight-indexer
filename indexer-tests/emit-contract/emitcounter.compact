import CompactStandardLibrary;

export ledger round: Counter;

witness private_increment(amount: Uint<16>): [];

constructor(
    initial_increment: Uint<16>
) {
  round.increment(disclose(initial_increment));
  private_increment(initial_increment);
}

export circuit increment(): [] {
  round.increment(1);
  private_increment(1);
}

export circuit emit_unpaused(): [] {
  emit(Unpaused {});
  round.increment(1);
  private_increment(1);
}

export circuit emit_misc(n: Bytes<32>, p: Bytes<256>): [] {
  emit(Misc { name: disclose(n), payload: disclose(p) });
  round.increment(1);
  private_increment(1);
}
