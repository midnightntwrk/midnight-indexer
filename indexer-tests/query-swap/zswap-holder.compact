pragma language_version >= 0.25.0;

import CompactStandardLibrary;

// A contract that holds real shielded (zswap) state: selfMint mints a shielded
// coin to the contract's own address (mintShieldedToken auto-receives when the
// recipient is kernel.self(), with matching claims), so a genuine commitment
// lands in this contract's zswap commitment tree. Used to QA that
// block.contractZswapState(address) reflects actual coin content over time.
export ledger mints: Counter;

export circuit selfMint(value: Uint<64>): [] {
  mintShieldedToken(
    pad(32, "mdn:indexer:zswap"),
    disclose(value),
    pad(32, "mdn:indexer:zswap:nonce"),
    right<ZswapCoinPublicKey, ContractAddress>(kernel.self())
  );
  mints.increment(1);
}
