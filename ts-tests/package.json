{
  "name": "midnight-indexer",
  "version": "1.0.0",
  "description": "Indexer is a component meant to optimize the flow of data from the node to the end users' applications. It retrieves the history of blocks, processes them, and stores data with a structure that is optimized.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "lint": "npx eslint '**/*.ts'",
    "ci_integration_tests": "DEBUG=testcontainers* NODE_OPTIONS=--experimental-vm-modules npx jest integration_tests --detectOpenHandles --runInBand",
    "testnet_indexing_benchmark": "DEBUG=testcontainers* NODE_OPTIONS=--experimental-vm-modules npx jest IndexerBenchmarkTestnet.test.ts --detectOpenHandles",
    "local_e2e_tests": "NODE_OPTIONS=--experimental-vm-modules npx jest e2e_tests --detectOpenHandles --testPathIgnorePatterns='.*Reorg.test.ts|.*IndexerBenchmarkTestnet.test.ts'",
    "reorg_tests": "DEBUG=testcontainers* NODE_OPTIONS=--experimental-vm-modules npx jest Reorg.test.ts --detectOpenHandles --testPathIgnorePatterns='.*IndexerBenchmarkTestnet.test.ts'",
    "integrated_env_tests": "DEBUG=testcontainers* NODE_OPTIONS=--experimental-vm-modules npx jest integration_tests e2e_tests/node_communication/ConnectToIntegratedEnv.test.ts --detectOpenHandles",
    "playground": "DEBUG=testcontainers*,testcode:* NODE_OPTIONS=--experimental-vm-modules npx jest integration_tests/Playground --detectOpenHandles",
    "compact": "sh ./compactc-manager.sh utils/counter/contract/counter.compact ./utils/counter/contract/managed/counter",
    "clean-results": "rm -rf reports/allure-results/*"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/input-output-hk/midnight-indexer/issues"
  },
  "homepage": "https://github.com/input-output-hk/midnight-indexer#readme",
  "resolutions": {
    "@midnight-ntwrk/compact-runtime/@midnight-ntwrk/onchain-runtime": "^0.2.5",
    "@midnight-ntwrk/zswap": "3.0.6"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "^0.7.0",
    "@midnight-ntwrk/ledger": "3.0.6",
    "@midnight-ntwrk/midnight-js-contracts": "0.2.5",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "0.2.5",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "0.2.5",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "0.2.5",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "0.2.5",
    "@midnight-ntwrk/midnight-js-network-id": "0.2.5",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "0.2.5",
    "@midnight-ntwrk/midnight-js-types": "0.2.5",
    "@midnight-ntwrk/onchain-runtime": "^0.2.5",
    "@midnight-ntwrk/wallet": "3.7.5-rc.1",
    "@midnight-ntwrk/wallet-api": "^3.5.0",
    "@midnight-ntwrk/zswap": "3.0.6",
    "@types/debug": "^4.1.12",
    "debug": "^4.4.0",
    "pino": "^8.18.0",
    "rxjs": "^7.8.1",
